<?xml version="1.0"?>
<ruleset name="bmm-publisher Coding Standard">
    <description>PSR-12 for src, bin and tests</description>

    <file>../src</file>
    <file>../bin</file>
    <file>../tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
