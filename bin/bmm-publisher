#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL);
ini_set('display_errors', '1');
ini_set('display_startup_errors', '1');

require __DIR__ . '/../vendor/autoload.php';

use OpenEHR\BmmPublisher\Console\Command\AsciidocCommand;
use OpenEHR\BmmPublisher\Console\Command\InlineSvgCommand;
use OpenEHR\BmmPublisher\Console\Command\PlantUmlCommand;
use OpenEHR\BmmPublisher\Console\Command\SplitJsonCommand;
use OpenEHR\BmmPublisher\Console\Command\YamlCommand;
use Symfony\Component\Console\Application;

try {
    $console = new Application('bmm-publisher', '0.5.0');
    $console->addCommand(new AsciidocCommand());
    $console->addCommand(new PlantUmlCommand());
    $console->addCommand(new InlineSvgCommand());
    $console->addCommand(new YamlCommand());
    $console->addCommand(new SplitJsonCommand());
    exit($console->run());
} catch (\Throwable $exception) {
    error_log((string) $exception);
    exit(1);
}
