	["TYPE_DEF_DURATION"] = <
		name = <"TYPE_DEF_DURATION">
		documentation = <"Rules meta-type representing the primitive type Duration.">
		ancestors = <"EXPR_TYPE_DEF", ...>
		properties = <
			["type_name"] = (P_BMM_SINGLE_PROPERTY) <
