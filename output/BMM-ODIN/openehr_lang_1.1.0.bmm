	["P_BMM_CONTAINER_PROPERTY"] = <
		name = <"P_BMM_CONTAINER_PROPERTY">
		documentation = <"Persistent form of `BMM_CONTAINER_PROPERTY`.">
		ancestors = <"P_BMM_PROPERTY", ...>
		properties = <
			["cardinality"] = (P_BMM_GENERIC_PROPERTY) <
				name = <"cardinality">
