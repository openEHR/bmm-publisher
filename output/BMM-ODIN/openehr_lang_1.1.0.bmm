				parameters = <
					["a_bmm_schema"] = (P_BMM_SINGLE_FUNCTION_PARAMETER) <
						name = <"a_bmm_schema">
						type = <"BMM_MODEL">
					>
					["a_class_def"] = (P_BMM_SINGLE_FUNCTION_PARAMETER) <
						name = <"a_class_def">
