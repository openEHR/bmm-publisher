@startuml

class Multiplicity_interval {
  + is_open() : Boolean [1]
  + is_optional() : Boolean [1]
  + is_mandatory() : Boolean [1]
  + is_prohibited() : Boolean [1]
}

class Proper_interval <T> {
}

abstract class Interval <T> {
  + lower : T [0..1]
  + upper : T [0..1]
  + lower_unbounded : Boolean [1]
  + upper_unbounded : Boolean [1]
  + lower_included : Boolean [1]
  + upper_included : Boolean [1]
  + {abstract} has( e : T [1] ) : Boolean [1]
  + {abstract} intersects( other : Interval [1] ) : Boolean [1]
  + {abstract} contains( other : Interval [1] ) : Boolean [1]
  + {abstract} is_equal( other : Any [1] ) : Boolean [1]
}

class Point_interval <T> {
  + lower_unbounded : Boolean [1]
  + upper_unbounded : Boolean [1]
  + lower_included : Boolean [1]
  + upper_included : Boolean [1]
}

class Cardinality {
  + interval : Multiplicity_interval [1]
  + is_ordered : Boolean [1]
  + is_unique : Boolean [1]
  + is_bag() : Boolean [1]
  + is_list() : Boolean [1]
  + is_set() : Boolean [1]
}

Proper_interval <|-- Multiplicity_interval
Interval <|-- Proper_interval
Interval <|-- Point_interval

@enduml