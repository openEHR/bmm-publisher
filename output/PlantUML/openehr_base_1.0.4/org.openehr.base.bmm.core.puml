@startuml

abstract class BMM_TYPE {
  + {abstract} effective_base_class() : BMM_CLASS [1]
  + {abstract} type_name() : String [1]
  + {abstract} has_subtypes() : Boolean [1]
  + {abstract} subtypes() : List<String> [1..*]
  + {abstract} flattened_type_list() : List<String> [1..*]
  + type_signature() : String [1]
  + is_primitive() : Boolean [1]
  + entity_metatype() : String [1]
}

abstract class BMM_CLASS {
  + name : String [1]
  + ancestors : List<String> [*]
  + package : BMM_PACKAGE [1]
  + properties : Hash<String,BMM_PROPERTY> [0..1]
  + source_schema_id : String [1]
  + immediate_descendants : List<BMM_CLASS> [*]
  + is_override : Boolean [1]
  + all_ancestors() : List<String> [*]
  + all_descendants() : List<String> [*]
  + suppliers() : List<String> [*]
  + suppliers_non_primitive() : List<String> [*]
  + supplier_closure() : List<String> [*]
  + package_path() : String [1]
  + class_path() : String [1]
  + flat_properties() : List<Hash<String,BMM_PROPERTY<BMM_TYPE>>> [*]
  + is_primitive() : Boolean [1]
  + is_abstract() : Boolean [1]
  + {abstract} type() : BMM_DEFINED_TYPE [1]
}

class BMM_PROPERTY <T> {
  + name : String [1]
  + is_mandatory : Boolean [0..1]
  + is_computed : Boolean [0..1]
  + type : T [1]
  + is_im_runtime : Boolean [0..1]
  + is_im_infrastructure : Boolean [0..1]
  + is_synthesised_generic : Boolean [0..1]
  + existence() : Multiplicity_interval [1]
  + display_name() : String [1]
}

class BMM_CONTAINER_TYPE {
  + container_class : BMM_GENERIC_CLASS [1]
  + base_type : BMM_UNITARY_TYPE [1]
  + type_name() : String [1]
  + effective_base_class() : BMM_CLASS [1]
  + is_abstract() : Boolean [1]
  + entity_metatype() : String [1]
  + flattened_type_list() : List<String> [1..*]
  + subtypes() : List<String> [1..*]
  + has_subtypes() : Boolean [1]
}

class BMM_GENERIC_TYPE {
  + generic_parameters : List<BMM_UNITARY_TYPE> [1..*]
  + base_class : BMM_GENERIC_CLASS [1]
  + type_name() : String [1]
  + type_signature() : String [1]
  + is_abstract() : Boolean [1]
  + flattened_type_list() : List<String> [1..*]
  + subtypes() : List<String> [1..*]
  + has_subtypes() : Boolean [1]
  + is_partially_closed() : Boolean [1]
  + effective_base_class() : BMM_GENERIC_CLASS [1]
}

class BMM_SIMPLE_TYPE {
  + type_name() : String [1]
  + is_abstract() : Boolean [1]
  + flattened_type_list() : List<String> [1..*]
  + subtypes() : List<String> [1..*]
  + has_subtypes() : Boolean [1]
  + effective_base_class() : BMM_SIMPLE_CLASS [1]
}

class BMM_ENUMERATION <T> {
  + item_names : List<String> [*]
  + item_values : T [0..1]
  + entity_metatype() : String [1]
  + name_map() : Hash<String,String> [1]
}

class BMM_ENUMERATION_STRING {
}

class BMM_ENUMERATION_INTEGER {
}

class BMM_PACKAGE {
  + name : String [1]
  + classes : List<BMM_CLASS> [*]
  + root_classes() : List<BMM_CLASS> [*]
  + path() : String [1]
}

class BMM_PARAMETER_TYPE {
  + name : String [1]
  + type_constraint : BMM_DEFINED_TYPE [0..1]
  + inheritance_precursor : BMM_PARAMETER_TYPE [0..1]
  + flattened_conforms_to_type() : String [1]
  + effective_conforms_to_type() : BMM_CLASS [1]
  + type_signature() : String [1]
  + is_primitive() : Boolean [1]
  + is_abstract() : Boolean [1]
  + entity_metatype() : String [1]
  + effective_base_class() : BMM_CLASS [1]
  + has_subtypes() : Boolean [1]
  + subtypes() : List<String> [1..*]
  + type_name() : String [1]
  + flattened_type_list() : List<String> [1..*]
}

abstract class BMM_ENTITY {
  + {abstract} entity_category() : String [1]
  + {abstract} entity_metatype() : String [1]
  + {abstract} is_abstract() : Boolean [1]
  + {abstract} is_primitive() : Boolean [1]
}

class BMM_CONTAINER_PROPERTY {
  + type : BMM_CONTAINER_TYPE [1]
  + cardinality : Multiplicity_interval [0..1]
  + display_name() : String [1]
}

class BMM_MODEL {
  + class_definitions : Hash<String,BMM_CLASS> [0..1]
  + model_name : String [1]
  + model_id() : String [1]
  + class_definition( a_name : String [1] ) : BMM_CLASS [1]
  + type_definition() : BMM_CLASS [1]
  + has_class_definition( a_class_name : String [1] ) : Boolean [1]
  + has_type_definition( a_type_name : String [1] ) : Boolean [1]
  + enumeration_definition( a_name : String [1] ) : BMM_ENUMERATION [1]
  + primitive_types() : List<String> [*]
  + enumeration_types() : List<String> [*]
  + property_definition() : BMM_PROPERTY [1]
  + ms_conformant_property_type( a_bmm_type_name : String [1], a_bmm_property_name : String [1], a_ms_property_name : String [1] ) : Boolean [1]
  + property_definition_at_path() : BMM_PROPERTY [1]
  + class_definition_at_path( a_type_name : String [1], a_prop_path : String [1] ) : BMM_CLASS [1]
  + all_ancestor_classes( a_class : String [1] ) : List<String> [*]
  + is_descendant_of( a_class_name : String [1], a_parent_class_name : String [1] ) : Boolean [1]
  + type_conforms_to( a_desc_type : String [1], an_anc_type : String [1] ) : Boolean [1]
  + any_class_definition() : BMM_SIMPLE_CLASS [1]
  + any_type_definition() : BMM_SIMPLE_TYPE [1]
}

class BMM_PACKAGE_CONTAINER {
  + packages : Hash<String,BMM_PACKAGE> [0..1]
  + package_at_path( a_path : String [1] ) : BMM_PACKAGE [0..1]
  + do_recursive_packages( action : PROCEDURE [1] ) : void [1]
  + has_package_path( a_path : String [1] ) : Boolean [1]
}

class BMM_GENERIC_CLASS {
  + generic_parameters : Hash<String,BMM_PARAMETER_TYPE> [1]
  + suppliers() : List<String> [*]
  + entity_metatype() : String [1]
  + type() : BMM_GENERIC_TYPE [1]
  + generic_parameter_conformance_type( a_name : String [1] ) : String [1]
}

class BMM_DEFINITIONS {
}

abstract class BMM_MODEL_ELEMENT {
  + documentation : String [0..1]
}

abstract class BMM_UNITARY_TYPE {
}

class BMM_INDEXED_CONTAINER_TYPE {
  + index_type : BMM_SIMPLE_TYPE [1]
}

abstract class BMM_DEFINED_TYPE {
  + base_class : BMM_CLASS [1]
}

class BMM_SIMPLE_CLASS {
  + type() : BMM_SIMPLE_TYPE [1]
  + entity_metatype() : String [1]
}

class BMM_MODEL_METADATA {
  + rm_publisher : String [1]
  + rm_release : String [1]
}

BMM_ENTITY <|-- BMM_TYPE
BMM_ENTITY <|-- BMM_CLASS
BMM_MODEL_ELEMENT <|-- BMM_CLASS
BMM_MODEL_ELEMENT <|-- BMM_PROPERTY
BMM_TYPE <|-- BMM_CONTAINER_TYPE
BMM_DEFINED_TYPE <|-- BMM_GENERIC_TYPE
BMM_DEFINED_TYPE <|-- BMM_SIMPLE_TYPE
BMM_SIMPLE_CLASS <|-- BMM_ENUMERATION
BMM_ENUMERATION <|-- BMM_ENUMERATION_STRING
BMM_ENUMERATION <|-- BMM_ENUMERATION_INTEGER
BMM_PACKAGE_CONTAINER <|-- BMM_PACKAGE
BMM_UNITARY_TYPE <|-- BMM_PARAMETER_TYPE
BMM_DEFINITIONS <|-- BMM_ENTITY
BMM_PROPERTY <|-- BMM_CONTAINER_PROPERTY
BMM_PACKAGE_CONTAINER <|-- BMM_MODEL
BMM_MODEL_METADATA <|-- BMM_MODEL
BMM_MODEL_ELEMENT <|-- BMM_PACKAGE_CONTAINER
BMM_CLASS <|-- BMM_GENERIC_CLASS
BMM_DEFINITIONS <|-- BMM_MODEL_ELEMENT
BMM_TYPE <|-- BMM_UNITARY_TYPE
BMM_CONTAINER_TYPE <|-- BMM_INDEXED_CONTAINER_TYPE
BMM_UNITARY_TYPE <|-- BMM_DEFINED_TYPE
BMM_CLASS <|-- BMM_SIMPLE_CLASS

@enduml