@startuml

class EXPR_BINARY_OPERATOR {
  + left_operand : EXPRESSION [1]
  + right_operand : EXPRESSION [1]
}

abstract class EXPR_OPERATOR  #whitesmoke;line:gray;line.dotted;text:gray {
  + precedence_overridden : Boolean [0..1]
  + operator_def : OPERATOR_DEF [1]
  + symbol : String [0..1]
}

abstract class EXPRESSION  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} type() : EXPR_TYPE_DEF [1]
}

abstract class EXPR_VALUE  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} value() : Any [1]
}

EXPR_VALUE <|-- EXPRESSION

EXPRESSION <|-- EXPR_OPERATOR

EXPR_OPERATOR <|-- EXPR_BINARY_OPERATOR


@enduml