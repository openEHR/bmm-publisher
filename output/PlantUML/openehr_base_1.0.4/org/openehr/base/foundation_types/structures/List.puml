@startuml

class List <T> {
  + first() : T [1]
  + last() : T [1]
}

abstract class Aggregate <T>  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} has( v : T [1] ) : Boolean [1]
  + {abstract} count() : Integer [1]
  + {abstract} is_empty() : Boolean [1]
}

Aggregate <|-- List


@enduml