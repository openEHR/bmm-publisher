@startuml

abstract class Iso8601_type {
  + value : String [1]
  + {abstract} is_partial() : Boolean [1]
  + {abstract} is_extended() : Boolean [1]
}

abstract class Ordered  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} infix <( other : Ordered [1] ) : Boolean [1]
}

Ordered <|-- Iso8601_type


@enduml