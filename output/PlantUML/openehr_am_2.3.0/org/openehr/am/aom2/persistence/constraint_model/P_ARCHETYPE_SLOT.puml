@startuml

class P_ARCHETYPE_SLOT {
  + includes : List<Any> [*]
  + excludes : List<Any> [*]
  + is_closed : Boolean [1]
}

abstract class P_C_OBJECT  #whitesmoke;line:gray;line.dotted;text:gray {
  + rm_type_name : String [1]
  + occurrences : String [0..1]
  + node_id : String [1]
  + is_deprecated : Boolean [0..1]
  + specialisation_depth() : Integer [1]
}

abstract class P_ARCHETYPE_CONSTRAINT  #whitesmoke;line:gray;line.dotted;text:gray {
}

P_ARCHETYPE_CONSTRAINT <|-- P_C_OBJECT

P_C_OBJECT <|-- P_ARCHETYPE_SLOT


@enduml