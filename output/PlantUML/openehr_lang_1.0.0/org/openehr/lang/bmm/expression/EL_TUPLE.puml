@startuml

class EL_TUPLE {
  + items : List<EL_TUPLE_ITEM> [*]
  + type : BMM_TUPLE_TYPE [1]
  + eval_type() : BMM_TYPE [1]
}

abstract class EL_INSTANCE_REF  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_TERMINAL  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_SIMPLE  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_EXPRESSION  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} eval_type() : BMM_TYPE [1]
  + is_boolean() : Boolean [1]
}

EL_EXPRESSION <|-- EL_SIMPLE

EL_SIMPLE <|-- EL_TERMINAL

EL_TERMINAL <|-- EL_INSTANCE_REF

EL_INSTANCE_REF <|-- EL_TUPLE


@enduml