@startuml

class OBJECT_REF {
  + id_namespace : String [1]
  + type : String [1]
  + id : OBJECT_ID [1]
}

abstract class OBJECT_ID {
  + value : String [1]
}

abstract class UID {
  + value : String [1]
}

class PARTY_REF {
}

class LOCATABLE_REF {
  + path : String [0..1]
  + id : UID_BASED_ID [1]
  + as_uri() : String [1]
}

class INTERNET_ID {
}

class UUID {
}

class ISO_OID {
}

class TERMINOLOGY_ID {
  + name() : String [1]
  + version_id() : String [1]
}

abstract class UID_BASED_ID {
  + root() : UID [1]
  + extension() : String [1]
  + has_extension() : Boolean [1]
}

class GENERIC_ID {
  + scheme : String [1]
}

class ARCHETYPE_ID {
  + qualified_rm_entity() : String [1]
  + domain_concept() : String [1]
  + rm_originator() : String [1]
  + rm_name() : String [1]
  + rm_entity() : String [1]
  + specialisation() : String [1]
  + version_id() : String [1]
}

class OBJECT_VERSION_ID {
  + object_id() : UID [1]
  + version_tree_id() : VERSION_TREE_ID [1]
  + creating_system_id() : UID [1]
  + is_branch() : Boolean [1]
}

class HIER_OBJECT_ID {
}

class VERSION_TREE_ID {
  + value : String [1]
  + trunk_version() : String [1]
  + is_branch() : Boolean [1]
  + branch_number() : String [1]
  + branch_version() : String [1]
}

OBJECT_REF <|-- PARTY_REF
OBJECT_REF <|-- LOCATABLE_REF
UID <|-- INTERNET_ID
UID <|-- UUID
UID <|-- ISO_OID
OBJECT_ID <|-- TERMINOLOGY_ID
OBJECT_ID <|-- UID_BASED_ID
OBJECT_ID <|-- GENERIC_ID
OBJECT_ID <|-- ARCHETYPE_ID
UID_BASED_ID <|-- OBJECT_VERSION_ID
UID_BASED_ID <|-- HIER_OBJECT_ID

@enduml