@startuml

class GENERIC_CONTENT_ITEM {
  + item_type : DV_CODED_TEXT [0..1]
  + item_type_version : String [0..1]
  + author : String [0..1]
  + creation_time : Iso8601_date_time [0..1]
  + authoriser : String [0..1]
  + authorisation_time : Iso8601_date_time [0..1]
  + item_status : DV_CODED_TEXT [0..1]
  + version_id : String [0..1]
  + version_set_id : String [0..1]
  + system_id : String [0..1]
  + other_details : List<String> [*]
  + item : LOCATABLE [0..1]
}

abstract class EXTRACT_CONTENT_ITEM  #whitesmoke;line:gray;line.dotted;text:gray {
  + uid : HIER_OBJECT_ID [1]
  + is_primary : Boolean [1]
  + is_changed : Boolean [0..1]
  + is_masked : Boolean [0..1]
  + item : Any [0..1]
}

abstract class EXTRACT_ITEM  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class LOCATABLE  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : DV_TEXT [1]
  + archetype_node_id : String [1]
  + uid : UID_BASED_ID [0..1]
  + links : List<LINK> [*]
  + archetype_details : ARCHETYPED [0..1]
  + feeder_audit : FEEDER_AUDIT [0..1]
  + concept() : DV_TEXT [1]
  + is_archetype_root() : Boolean [1]
}

abstract class PATHABLE  #whitesmoke;line:gray;line.dotted;text:gray {
  + parent() : PATHABLE [1]
  + item_at_path( a_path : String [1] ) : Any [1]
  + items_at_path( a_path : String [1] ) : List<Any> [*]
  + path_exists( a_path : String [1] ) : Boolean [1]
  + path_unique( a_path : String [1] ) : Boolean [1]
  + path_of_item( a_loc : PATHABLE [1] ) : String [1]
}

PATHABLE <|-- LOCATABLE

LOCATABLE <|-- EXTRACT_ITEM

EXTRACT_ITEM <|-- EXTRACT_CONTENT_ITEM

EXTRACT_CONTENT_ITEM <|-- GENERIC_CONTENT_ITEM


@enduml