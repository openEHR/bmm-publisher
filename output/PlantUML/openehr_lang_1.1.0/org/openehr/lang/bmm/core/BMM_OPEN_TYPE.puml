@startuml

class BMM_OPEN_TYPE {
  + generic_constraint : BMM_GENERIC_PARAMETER [1]
  + conformance_type_name() : String [1]
}

abstract class BMM_TYPE  #whitesmoke;line:gray;line.dotted;text:gray {
  + has_type_substitutions() : Boolean [1]
  + type_substitutions() : List<String> [*]
}

abstract class BMM_TYPE_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class BMM_CLASSIFIER  #whitesmoke;line:gray;line.dotted;text:gray {
  + type_name() : String [1]
  + type_category() : String [1]
  + type_signature() : String [1]
  + base_class() : BMM_CLASS [1]
  + flattened_type_list() : List<String> [*]
}

abstract class BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + documentation : String [0..1]
}

class BMM_DEFINITIONS  #whitesmoke;line:gray;line.dotted;text:gray {
}

BMM_DEFINITIONS <|-- BMM_MODEL_ELEMENT

BMM_MODEL_ELEMENT <|-- BMM_CLASSIFIER

BMM_CLASSIFIER <|-- BMM_TYPE_ELEMENT

BMM_TYPE_ELEMENT <|-- BMM_TYPE

BMM_TYPE <|-- BMM_OPEN_TYPE


@enduml