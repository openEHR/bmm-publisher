@startuml

class BMM_MODEL {
  + class_definitions : List<String> [*]
  + used_models : List<BMM_MODEL> [*]
  + modules : Hash<String,BMM_MODULE> [0..1]
  + model_id() : String [1]
  + class_definition( a_name : String [1] ) : BMM_CLASS [1]
  + type_definition() : BMM_CLASS [1]
  + has_class_definition( a_class_name : String [1] ) : Boolean [1]
  + has_type_definition( a_type_name : String [1] ) : Boolean [1]
  + enumeration_definition( a_name : String [1] ) : BMM_ENUMERATION [1]
  + primitive_types() : List<String> [*]
  + enumeration_types() : List<String> [*]
  + property_definition() : BMM_PROPERTY [1]
  + ms_conformant_property_type( a_bmm_type_name : String [1], a_bmm_property_name : String [1], a_ms_property_name : String [1] ) : Boolean [1]
  + property_definition_at_path() : BMM_PROPERTY [1]
  + class_definition_at_path( a_type_name : String [1], a_prop_path : String [1] ) : BMM_CLASS [1]
  + all_ancestor_classes( a_class : String [1] ) : List<String> [*]
  + is_descendant_of( a_class_name : String [1], a_parent_class_name : String [1] ) : Boolean [1]
  + type_conforms_to( a_desc_type : String [1], an_anc_type : String [1] ) : Boolean [1]
  + subtypes( a_type : String [1] ) : List<String> [1..*]
  + any_class_definition() : BMM_SIMPLE_CLASS [1]
  + any_type_definition() : BMM_SIMPLE_TYPE [1]
  + boolean_type_definition() : BMM_SIMPLE_TYPE [1]
}

abstract class BMM_PACKAGE_CONTAINER  #whitesmoke;line:gray;line.dotted;text:gray {
  + packages : Hash<String,BMM_PACKAGE> [0..1]
  + scope : BMM_PACKAGE_CONTAINER [1]
  + package_at_path( a_path : String [1] ) : BMM_PACKAGE [0..1]
  + do_recursive_packages( action : EL_PROCEDURE_AGENT [1] ) : void [1]
  + has_package_path( a_path : String [1] ) : Boolean [1]
}

abstract class BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : String [1]
  + documentation : Hash<String,Any> [0..1]
  + scope : BMM_MODEL_ELEMENT [1]
  + extensions : Hash<String,Any> [0..1]
  + is_root_scope() : Boolean [1]
}

BMM_MODEL_ELEMENT <|-- BMM_PACKAGE_CONTAINER

BMM_PACKAGE_CONTAINER <|-- BMM_MODEL

class BMM_MODEL_METADATA  #whitesmoke;line:gray;line.dotted;text:gray {
  + rm_publisher : String [1]
  + rm_release : String [1]
}

BMM_MODEL_METADATA <|-- BMM_MODEL


@enduml