@startuml

class P_BMM_SINGLE_PROPERTY_OPEN {
  + type_ref : P_BMM_OPEN_TYPE [0..1]
  + type : String [0..1]
  + bmm_property : BMM_UNITARY_PROPERTY [0..1]
  + type_def() : P_BMM_OPEN_TYPE [1]
}

abstract class P_BMM_PROPERTY  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : String [1]
  + is_mandatory : Boolean [0..1]
  + is_computed : Boolean [0..1]
  + is_im_infrastructure : Boolean [0..1]
  + is_im_runtime : Boolean [0..1]
  + type_def : P_BMM_TYPE [0..1]
  + bmm_property : BMM_PROPERTY [0..1]
  + create_bmm_property( a_bmm_schema : BMM_MODEL [1], a_class_def : BMM_CLASS [1] ) : void [1]
}

abstract class P_BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + documentation : String [0..1]
}

P_BMM_MODEL_ELEMENT <|-- P_BMM_PROPERTY

P_BMM_PROPERTY <|-- P_BMM_SINGLE_PROPERTY_OPEN


@enduml