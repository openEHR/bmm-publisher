@startuml

class P_BMM_SCHEMA {
  + bmm_version : String [1]
  + includes : Hash<String,BMM_INCLUDE_SPEC> [0..1]
  + primitive_types : List<P_BMM_CLASS> [*]
  + class_definitions : List<P_BMM_CLASS> [*]
  + validate_created() : void [1]
  + load_finalise() : void [1]
  + merge( other : P_BMM_SCHEMA [1] ) : void [1]
  + validate() : void [1]
  + create_bmm_model() : void [1]
  + canonical_packages() : P_BMM_PACKAGE [1]
}

class P_BMM_PACKAGE_CONTAINER #whitesmoke;line:gray;line.dotted;text:gray {
  + packages : Hash<String,P_BMM_PACKAGE> [1]
}

P_BMM_PACKAGE_CONTAINER <|-- P_BMM_SCHEMA

class BMM_SCHEMA_CORE #whitesmoke;line:gray;line.dotted;text:gray {
  + rm_publisher : String [1]
  + rm_release : String [1]
  + schema_name : String [1]
  + schema_revision : String [1]
  + schema_lifecycle_state : String [1]
  + schema_author : String [1]
  + schema_description : String [1]
  + schema_contributors : List<String> [*]
  + archetype_parent_class : String [0..1]
  + archetype_data_value_parent_class : String [0..1]
  + archetype_rm_closure_packages : List<String> [*]
  + archetype_visualise_descendants_of : String [0..1]
  + schema_id() : String [1]
}

BMM_SCHEMA_CORE <|-- P_BMM_SCHEMA


@enduml