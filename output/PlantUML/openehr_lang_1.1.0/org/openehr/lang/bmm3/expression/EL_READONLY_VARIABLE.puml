@startuml

class EL_READONLY_VARIABLE {
  + definition : BMM_READONLY_VARIABLE [1]
  + is_writable : Boolean [1]
}

abstract class EL_VARIABLE  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_VALUE_GENERATOR  #whitesmoke;line:gray;line.dotted;text:gray {
  + is_writable : Boolean [1]
  + name : String [1]
  + reference() : String [1]
}

abstract class EL_SIMPLE  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_TERMINAL  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EL_EXPRESSION  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} eval_type() : BMM_TYPE [1]
  + is_boolean() : Boolean [1]
}

EL_EXPRESSION <|-- EL_TERMINAL

EL_TERMINAL <|-- EL_SIMPLE

EL_SIMPLE <|-- EL_VALUE_GENERATOR

EL_VALUE_GENERATOR <|-- EL_VARIABLE

EL_VARIABLE <|-- EL_READONLY_VARIABLE


@enduml