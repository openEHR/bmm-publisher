@startuml

class BMM_CONSTANT {
  + generator : BMM_LITERAL_VALUE [1]
}

class BMM_CONTAINER_PROPERTY {
  + cardinality : Multiplicity_interval [0..1]
  + type : BMM_CONTAINER_TYPE [1]
  + display_name() : String [1]
}

class BMM_FUNCTION {
  + operator_definition : BMM_OPERATOR [0..1]
  + result : BMM_RESULT [1]
}

class BMM_LOCAL {
}

class BMM_OPERATOR {
  + position : BMM_OPERATOR_POSITION [1]
  + symbols : List<String> [1..*]
  + name : String [1]
}

abstract class BMM_PROPERTY {
  + is_im_runtime : Boolean [0..1]
  + is_im_infrastructure : Boolean [0..1]
  + is_composition : Boolean [0..1]
  + existence() : Multiplicity_interval [1]
  + display_name() : String [1]
}

abstract class BMM_ROUTINE {
  + parameters : List<BMM_PARAMETER> [*]
  + pre_conditions : List<BMM_ASSERTION> [*]
  + post_conditions : List<BMM_ASSERTION> [*]
  + definition : BMM_ROUTINE_DEFINITION [0..1]
  + arity() : Integer [1]
}

class BMM_PARAMETER {
  + direction : BMM_PARAMETER_DIRECTION [0..1]
}

abstract class BMM_VARIABLE {
  + scope : BMM_ROUTINE [1]
}

class BMM_PROCEDURE {
  + type : BMM_STATUS_TYPE [1]
  + signature() : BMM_PROCEDURE_TYPE [1]
}

class BMM_UNITARY_PROPERTY {
  + type : BMM_UNITARY_TYPE [1]
}

class BMM_INDEXED_CONTAINER_PROPERTY {
  + type : BMM_INDEXED_CONTAINER_TYPE [1]
  + display_name() : String [1]
}

abstract class BMM_INSTANTIABLE_FEATURE {
}

class BMM_RESULT {
  + name : String [1]
}

abstract class BMM_FEATURE_EXTENSION {
}

abstract class BMM_ROUTINE_DEFINITION {
}

class BMM_EXTERNAL_ROUTINE {
  + meta_data : Hash<String,String> [1]
  + argument_mapping : Hash<String,String> [0..1]
}

class BMM_FEATURE_GROUP {
  + name : String [1]
  + properties : Hash<String,String> [1]
  + features : List<BMM_FEATURE> [*]
  + visibility : BMM_VISIBILITY [0..1]
}

abstract class BMM_VISIBILITY {
}

abstract class BMM_FEATURE {
  + is_synthesised_generic : Boolean [0..1]
  + feature_extensions : List<BMM_FEATURE_EXTENSION> [*]
  + group : BMM_FEATURE_GROUP [1]
  + scope : BMM_CLASS [1]
}

class BMM_SELF {
  + name : String [1]
}

abstract class BMM_WRITABLE_VARIABLE {
}

abstract class BMM_READONLY_VARIABLE {
}

class BMM_SINGLETON {
  + generator : BMM_ROUTINE_DEFINITION [1]
}

abstract class BMM_STATIC {
}

class BMM_LOCAL_ROUTINE {
  + locals : List<BMM_LOCAL> [*]
  + body : BMM_STATEMENT_BLOCK [1]
}

enum BMM_OPERATOR_POSITION {
  prefix 
  infix 
}

enum BMM_PARAMETER_DIRECTION {
  in 
  out 
  in_out 
}

BMM_STATIC <|-- BMM_CONSTANT
BMM_PROPERTY <|-- BMM_CONTAINER_PROPERTY
BMM_ROUTINE <|-- BMM_FUNCTION
BMM_WRITABLE_VARIABLE <|-- BMM_LOCAL
BMM_INSTANTIABLE_FEATURE <|-- BMM_PROPERTY
BMM_FEATURE <|-- BMM_ROUTINE
BMM_READONLY_VARIABLE <|-- BMM_PARAMETER
BMM_FORMAL_ELEMENT <|-- BMM_VARIABLE
BMM_ROUTINE <|-- BMM_PROCEDURE
BMM_PROPERTY <|-- BMM_UNITARY_PROPERTY
BMM_CONTAINER_PROPERTY <|-- BMM_INDEXED_CONTAINER_PROPERTY
BMM_FEATURE <|-- BMM_INSTANTIABLE_FEATURE
BMM_WRITABLE_VARIABLE <|-- BMM_RESULT
BMM_ROUTINE_DEFINITION <|-- BMM_EXTERNAL_ROUTINE
BMM_FORMAL_ELEMENT <|-- BMM_FEATURE
BMM_READONLY_VARIABLE <|-- BMM_SELF
BMM_VARIABLE <|-- BMM_WRITABLE_VARIABLE
BMM_VARIABLE <|-- BMM_READONLY_VARIABLE
BMM_STATIC <|-- BMM_SINGLETON
BMM_INSTANTIABLE_FEATURE <|-- BMM_STATIC
BMM_ROUTINE_DEFINITION <|-- BMM_LOCAL_ROUTINE

@enduml