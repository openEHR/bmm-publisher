@startuml

class EL_BINARY_OPERATOR {
  + left_operand : EL_EXPRESSION [1]
  + right_operand : EL_EXPRESSION [1]
}

abstract class EL_EXPRESSION {
  + {abstract} eval_type() : BMM_TYPE [1]
  + is_boolean() : Boolean [1]
}

class EL_LITERAL {
  + value : BMM_LITERAL_VALUE<BMM_TYPE> [1]
  + eval_type() : BMM_TYPE [1]
}

abstract class EL_OPERATOR {
  + precedence_overridden : Boolean [0..1]
  + symbol : String [0..1]
  + call : EL_FUNCTION_CALL [1]
  + operator_definition() : BMM_OPERATOR [1]
  + equivalent_call() : EL_FUNCTION_CALL [1]
}

class EL_UNARY_OPERATOR {
  + operand : EL_EXPRESSION [1]
}

class EL_PROPERTY_REF {
  + definition : BMM_PROPERTY [1]
  + is_writable : Boolean [1]
  + eval_type() : BMM_TYPE [1]
}

abstract class EL_PREDICATE {
  + operand : EL_VALUE_GENERATOR [1]
  + eval_type() : BMM_SIMPLE_TYPE [1]
}

class EL_DEFINED {
}

class EL_FUNCTION_CALL {
  + agent : EL_FUNCTION_AGENT [1]
  + is_writable : Boolean [1]
  + eval_type() : BMM_TYPE [1]
  + reference() : String [1]
}

abstract class EL_AGENT_CALL {
  + agent : EL_AGENT [1]
}

abstract class EL_AGENT {
  + name : String [1]
  + closed_args : EL_TUPLE [0..1]
  + open_args : List<String> [*]
  + definition : BMM_ROUTINE [0..1]
  + is_writable : Boolean [1]
  + eval_type() : BMM_ROUTINE_TYPE [1]
  + is_callable() : Boolean [1]
  + reference() : String [1]
}

class EL_TUPLE_ITEM {
  + item : EL_EXPRESSION [0..1]
  + name : String [0..1]
}

class EL_PROCEDURE_AGENT {
  + definition : BMM_PROCEDURE [0..1]
  + eval_type() : BMM_PROCEDURE_TYPE [1]
}

class EL_TUPLE {
  + items : List<EL_TUPLE_ITEM> [*]
  + type : BMM_TUPLE_TYPE [1]
  + eval_type() : BMM_TYPE [1]
}

class EL_FUNCTION_AGENT {
  + definition : BMM_FUNCTION [0..1]
  + eval_type() : BMM_FUNCTION_TYPE [1]
}

class EL_ATTACHED {
}

abstract class EL_VALUE_GENERATOR {
  + is_writable : Boolean [1]
  + name : String [1]
  + reference() : String [1]
}

class EL_BOOLEAN_EXPRESSION {
}

class EL_TYPE_REF {
  + type : BMM_TYPE [1]
  + is_mutable : Boolean [1]
  + eval_type() : BMM_TYPE [1]
}

abstract class EL_FEATURE_REF {
  + scoper : EL_VALUE_GENERATOR [0..1]
  + reference() : String [1]
}

class EL_CONDITIONAL_EXPRESSION <T> {
  + condition : EL_EXPRESSION [1]
}

class EL_CONDITION_CHAIN <T> {
  + items : List<EL_CONDITIONAL_EXPRESSION<T>> [1..*]
}

abstract class EL_CONSTRAINED {
  + base_expression : EL_EXPRESSION [1]
}

class EL_CASE_TABLE <T> {
  + items : List<EL_CASE<T>> [1..*]
  + test_value : EL_VALUE_GENERATOR [1]
}

class EL_CASE <T> {
  + value_constraint : C_OBJECT [1]
}

abstract class EL_DECISION_TABLE <T> {
  + items : List<EL_DECISION_BRANCH<T>> [1..*]
  + else : T [1]
}

abstract class EL_DECISION_BRANCH <T> {
  + result : T [1]
}

abstract class EL_VARIABLE {
}

abstract class EL_TERMINAL {
}

abstract class EL_SIMPLE {
}

class EL_STATIC_REF {
  + definition : BMM_STATIC [1]
  + is_writable : Boolean [1]
}

class EL_WRITABLE_VARIABLE {
  + definition : BMM_WRITABLE_VARIABLE [1]
  + is_writable : Boolean [1]
}

class EL_READONLY_VARIABLE {
  + definition : BMM_READONLY_VARIABLE [1]
  + is_writable : Boolean [1]
}

EL_OPERATOR <|-- EL_BINARY_OPERATOR
EL_SIMPLE <|-- EL_LITERAL
EL_EXPRESSION <|-- EL_OPERATOR
EL_OPERATOR <|-- EL_UNARY_OPERATOR
EL_FEATURE_REF <|-- EL_PROPERTY_REF
EL_SIMPLE <|-- EL_PREDICATE
EL_PREDICATE <|-- EL_DEFINED
EL_FEATURE_REF <|-- EL_FUNCTION_CALL
EL_AGENT_CALL <|-- EL_FUNCTION_CALL
EL_FEATURE_REF <|-- EL_AGENT
EL_AGENT <|-- EL_PROCEDURE_AGENT
EL_EXPRESSION <|-- EL_TUPLE
EL_AGENT <|-- EL_FUNCTION_AGENT
EL_PREDICATE <|-- EL_ATTACHED
EL_SIMPLE <|-- EL_VALUE_GENERATOR
EL_CONSTRAINED <|-- EL_BOOLEAN_EXPRESSION
EL_VALUE_GENERATOR <|-- EL_TYPE_REF
EL_VALUE_GENERATOR <|-- EL_FEATURE_REF
EL_DECISION_BRANCH <|-- EL_CONDITIONAL_EXPRESSION
EL_DECISION_TABLE <|-- EL_CONDITION_CHAIN
EL_EXPRESSION <|-- EL_CONSTRAINED
EL_DECISION_TABLE <|-- EL_CASE_TABLE
EL_DECISION_BRANCH <|-- EL_CASE
EL_TERMINAL <|-- EL_DECISION_TABLE
EL_VALUE_GENERATOR <|-- EL_VARIABLE
EL_EXPRESSION <|-- EL_TERMINAL
EL_TERMINAL <|-- EL_SIMPLE
EL_FEATURE_REF <|-- EL_STATIC_REF
EL_VARIABLE <|-- EL_WRITABLE_VARIABLE
EL_VARIABLE <|-- EL_READONLY_VARIABLE

@enduml