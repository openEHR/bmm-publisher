@startuml

class C_BOOLEAN {
  + constraint : List<Boolean> [*]
  + assumed_value : Boolean [0..1]
  + default_value : Boolean [1]
  + prototype_value() : Boolean [1]
  + any_allowed() : Boolean [1]
  + c_value_conforms_to( other : C_BOOLEAN [1] ) : Boolean [1]
  + c_value_congruent_to( other : C_BOOLEAN [1] ) : Boolean [1]
}

class C_STRING {
  + constraint : List<String> [*]
  + default_value : String [1]
  + assumed_value : String [0..1]
  + prototype_value() : String [1]
  + valid_value( a_value : String [1] ) : Boolean [1]
  + any_allowed() : Boolean [1]
  + c_value_conforms_to( other : C_STRING [1] ) : Boolean [1]
  + c_value_congruent_to( other : C_STRING [1] ) : Boolean [1]
}

class C_INTEGER {
  + constraint : List<Interval<Integer>> [*]
}

class C_REAL {
  + constraint : List<Interval<Real>> [*]
}

abstract class C_ORDERED <T> {
  + constraint : List<Interval<T>> [*]
  + any_allowed() : Boolean [1]
  + c_value_conforms_to( other : C_ORDERED [1] ) : Boolean [1]
  + c_value_congruent_to( other : C_ORDERED [1] ) : Boolean [1]
}

class C_TERMINOLOGY_CODE {
  + constraint : String [1]
  + assumed_value : Terminology_code [0..1]
  + default_value : Terminology_code [1]
  + value_set_expanded() : List<String> [*]
  + value_set_substituted() : List<Uri> [*]
  + value_set_resolved() : List<Terminology_code> [*]
  + valid_value( a_value : Terminology_code [1] ) : Boolean [1]
  + prototype_value() : Terminology_code [1]
  + any_allowed() : Boolean [1]
  + c_value_conforms_to( other : C_TERMINOLOGY_CODE [1] ) : Boolean [1]
  + c_value_congruent_to( other : C_TERMINOLOGY_CODE [1] ) : Boolean [1]
}

abstract class C_TEMPORAL <T> {
  + pattern_constraint : String [0..1]
  + {abstract} valid_pattern_constraint( a_pattern : String [1] ) : Boolean [1]
  + {abstract} valid_pattern_constraint_replacement( a_pattern : String [1], an_other_pattern : String [1] ) : Boolean [1]
  + any_allowed() : Boolean [1]
  + c_value_conforms_to( other : C_ORDERED [1] ) : Boolean [1]
  + c_value_congruent_to( other : C_ORDERED [1] ) : Boolean [1]
}

class C_TIME {
  + constraint : List<Interval<Iso8601_time>> [*]
  + minute_validity() : VALIDITY_KIND [1]
  + second_validity() : VALIDITY_KIND [1]
  + millisecond_validity() : VALIDITY_KIND [1]
  + timezone_validity() : VALIDITY_KIND [1]
}

class C_DATE {
  + constraint : List<Interval<Iso8601_date>> [*]
  + month_validity() : VALIDITY_KIND [1]
  + day_validity() : VALIDITY_KIND [1]
  + timezone_validity() : VALIDITY_KIND [1]
}

class C_DATE_TIME {
  + constraint : List<Interval<Iso8601_date_time>> [*]
  + month_validity() : VALIDITY_KIND [1]
  + day_validity() : VALIDITY_KIND [1]
  + timezone_validity() : VALIDITY_KIND [1]
  + minute_validity() : VALIDITY_KIND [1]
  + second_validity() : VALIDITY_KIND [1]
  + millisecond_validity() : VALIDITY_KIND [1]
}

class C_DURATION {
  + constraint : List<Interval<Iso8601_duration>> [*]
  + years_allowed() : Boolean [1]
  + months_allowed() : Boolean [1]
  + weeks_allowed() : Boolean [1]
  + days_allowed() : Boolean [1]
  + hours_allowed() : Boolean [1]
  + minutes_allowed() : Boolean [1]
  + seconds_allowed() : Boolean [1]
}

C_PRIMITIVE_OBJECT <|-- C_BOOLEAN
C_PRIMITIVE_OBJECT <|-- C_STRING
C_ORDERED <|-- C_INTEGER
C_ORDERED <|-- C_REAL
C_PRIMITIVE_OBJECT <|-- C_ORDERED
C_PRIMITIVE_OBJECT <|-- C_TERMINOLOGY_CODE
C_ORDERED <|-- C_TEMPORAL
C_TEMPORAL <|-- C_TIME
C_TEMPORAL <|-- C_DATE
C_TEMPORAL <|-- C_DATE_TIME
C_TEMPORAL <|-- C_DURATION

@enduml