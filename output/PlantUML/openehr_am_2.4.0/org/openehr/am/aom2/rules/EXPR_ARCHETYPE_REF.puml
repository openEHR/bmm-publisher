@startuml

class EXPR_ARCHETYPE_REF {
  + path : String [1]
  + item : ARCHETYPE_CONSTRAINT [1]
}

class EXPR_VALUE_REF  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class EXPR_LEAF  #whitesmoke;line:gray;line.dotted;text:gray {
  + item : Any [0..1]
}

abstract class EXPRESSION  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} type() : EXPR_TYPE_DEF [1]
}

abstract class EXPR_VALUE  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} value() : Any [1]
}

EXPR_VALUE <|-- EXPRESSION

EXPRESSION <|-- EXPR_LEAF

EXPR_LEAF <|-- EXPR_VALUE_REF

EXPR_VALUE_REF <|-- EXPR_ARCHETYPE_REF


@enduml