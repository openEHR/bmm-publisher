@startuml

class DV_TIME {
  + value : String [1]
  + magnitude() : Real [1]
  + is_strictly_comparable_to( other : DV_ORDERED [1] ) : Boolean [1]
  + add( a_diff : DV_AMOUNT [1] ) : DV_ABSOLUTE_QUANTITY [1]
  + subtract( a_diif : DV_AMOUNT [1] ) : DV_ABSOLUTE_QUANTITY [1]
  + operator=( source : DV_TIME [1] ) : DV_TIME [1]
  + diff( other : DV_TIME [1] ) : DV_DURATION [1]
}

abstract class DV_TEMPORAL  #whitesmoke;line:gray;line.dotted;text:gray {
  + accuracy : DV_DURATION [0..1]
  + diff( other : DV_TEMPORAL [1] ) : DV_DURATION [1]
}

abstract class DV_ABSOLUTE_QUANTITY  #whitesmoke;line:gray;line.dotted;text:gray {
  + accuracy : DV_AMOUNT [0..1]
  + {abstract} diff( other : DV_ABSOLUTE_QUANTITY [1] ) : DV_AMOUNT [1]
  + {abstract} add( a_diff : DV_AMOUNT [1] ) : DV_ABSOLUTE_QUANTITY [1]
  + {abstract} subtract( a_diif : DV_AMOUNT [1] ) : DV_ABSOLUTE_QUANTITY [1]
}

abstract class DV_QUANTIFIED  #whitesmoke;line:gray;line.dotted;text:gray {
  + magnitude_status : String [0..1]
  + accuracy : Any [0..1]
  + valid_magnitude_status() : Boolean [1]
  + {abstract} magnitude() : Ordered_Numeric [1]
  + accuracy_unknown() : Boolean [1]
}

abstract class DV_ORDERED  #whitesmoke;line:gray;line.dotted;text:gray {
  + normal_status : CODE_PHRASE [0..1]
  + normal_range : DV_INTERVAL [0..1]
  + other_reference_ranges : List<REFERENCE_RANGE<DV_ORDERED>> [*]
  + {abstract} is_strictly_comparable_to( other : DV_ORDERED [1] ) : Boolean [1]
  + is_simple() : Boolean [1]
  + is_normal() : Boolean [1]
  + {abstract} infix <( other : Ordered [1] ) : Boolean [1]
}

abstract class DATA_VALUE  #whitesmoke;line:gray;line.dotted;text:gray {
}

DATA_VALUE <|-- DV_ORDERED

abstract class Ordered  #whitesmoke;line:gray;line.dotted;text:gray {
  + {abstract} infix <( other : Ordered [1] ) : Boolean [1]
}

Ordered <|-- DV_ORDERED

DV_ORDERED <|-- DV_QUANTIFIED

DV_QUANTIFIED <|-- DV_ABSOLUTE_QUANTITY

DV_ABSOLUTE_QUANTITY <|-- DV_TEMPORAL

DV_TEMPORAL <|-- DV_TIME

ISO8601_TIME <|-- DV_TIME


@enduml