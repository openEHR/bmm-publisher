@startuml

class DV_DURATION {
  + value : String [1]
  + add( other : DV_DURATION [1] ) : DV_DURATION [1]
  + subtract( other : DV_DURATION [1] ) : DV_DURATION [1]
  + multiply( factor : Real [1] ) : DV_DURATION [1]
  + less_than( other : DV_DURATION [1] ) : Boolean [1]
  + is_strictly_comparable_to( other : DV_DURATION [1] ) : Boolean [1]
  + negative() : DV_DURATION [1]
  + magnitude() : Double [1]
}

abstract class DV_TEMPORAL {
  + accuracy : DV_DURATION [0..1]
  + {abstract} add( a_diff : DV_DURATION [1] ) : DV_TEMPORAL [1]
  + {abstract} subtract( a_diff : DV_DURATION [1] ) : DV_TEMPORAL [1]
  + {abstract} diff( other : DV_TEMPORAL [1] ) : DV_DURATION [1]
}

class DV_DATE {
  + value : String [1]
  + magnitude() : Integer [1]
  + is_equal( other : DV_QUANTIFIED [1] ) : Boolean [1]
  + add( a_diff : DV_DURATION [1] ) : DV_DATE [1]
  + subtract( a_diff : DV_DURATION [1] ) : DV_DATE [1]
  + diff( other : DV_DATE [1] ) : DV_DURATION [1]
  + less_than( other : DV_DATE [1] ) : Boolean [1]
  + is_strictly_comparable_to( other : DV_DATE [1] ) : Boolean [1]
}

class DV_TIME {
  + value : String [1]
  + magnitude() : Real [1]
  + add( a_diff : DV_DURATION [1] ) : DV_TIME [1]
  + subtract( a_diff : DV_DURATION [1] ) : DV_TIME [1]
  + diff( other : DV_TIME [1] ) : DV_DURATION [1]
  + less_than( other : DV_TIME [1] ) : Boolean [1]
  + is_strictly_comparable_to( other : DV_TIME [1] ) : Boolean [1]
}

class DV_DATE_TIME {
  + value : String [1]
  + magnitude() : Double [1]
  + add( a_diff : DV_DURATION [1] ) : DV_DATE_TIME [1]
  + subtract( a_diff : DV_DURATION [1] ) : DV_DATE_TIME [1]
  + diff( other : DV_DATE_TIME [1] ) : DV_DURATION [1]
  + less_than( other : DV_DATE_TIME [1] ) : Boolean [1]
  + is_strictly_comparable_to( other : DV_DATE_TIME [1] ) : Boolean [1]
}

DV_AMOUNT <|-- DV_DURATION
Iso8601_duration <|-- DV_DURATION
DV_ABSOLUTE_QUANTITY <|-- DV_TEMPORAL
DV_TEMPORAL <|-- DV_DATE
Iso8601_date <|-- DV_DATE
DV_TEMPORAL <|-- DV_TIME
Iso8601_time <|-- DV_TIME
DV_TEMPORAL <|-- DV_DATE_TIME
Iso8601_date_time <|-- DV_DATE_TIME

@enduml