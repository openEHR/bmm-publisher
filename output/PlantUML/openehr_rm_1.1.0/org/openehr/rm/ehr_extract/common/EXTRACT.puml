@startuml

class EXTRACT {
  + chapters : List<EXTRACT_CHAPTER> [*]
  + specification : EXTRACT_SPEC [0..1]
  + request_id : HIER_OBJECT_ID [0..1]
  + time_created : DV_DATE_TIME [1]
  + system_id : HIER_OBJECT_ID [1]
  + sequence_nr : Integer [1]
  + participations : List<EXTRACT_PARTICIPATION> [*]
}

abstract class LOCATABLE  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : DV_TEXT [1]
  + archetype_node_id : String [1]
  + uid : UID_BASED_ID [0..1]
  + links : List<LINK> [*]
  + archetype_details : ARCHETYPED [0..1]
  + feeder_audit : FEEDER_AUDIT [0..1]
  + concept() : DV_TEXT [1]
  + is_archetype_root() : Boolean [1]
}

abstract class PATHABLE  #whitesmoke;line:gray;line.dotted;text:gray {
  + parent() : PATHABLE [1]
  + item_at_path( a_path : String [1] ) : Any [1]
  + items_at_path( a_path : String [1] ) : List<Any> [*]
  + path_exists( a_path : String [1] ) : Boolean [1]
  + path_unique( a_path : String [1] ) : Boolean [1]
  + path_of_item( a_loc : PATHABLE [1] ) : String [1]
}

PATHABLE <|-- LOCATABLE

LOCATABLE <|-- EXTRACT


@enduml