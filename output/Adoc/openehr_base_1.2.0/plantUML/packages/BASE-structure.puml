@startuml

class Hash <K, V> {
  + has_key( a_key : K [1] ) : Boolean [1]
  + item( a_key : K [1] ) : V [1]
}

abstract class Container <T> {
  + {abstract} has( v : T [1] ) : Boolean [1]
  + {abstract} count() : Integer [1]
  + {abstract} is_empty() : Boolean [1]
  + there_exists( test : Operation [1] ) : Boolean [1]
  + for_all( test : Operation [1] ) : Boolean [1]
  + matching( test : Operation [1] ) : List<T> [*]
  + select( test : Operation [1] ) : T [0..1]
}

class List <T> {
  + first() : T [1]
  + last() : T [1]
}

class Set <T> {
}

class Array <T> {
  + item( a_key : Integer [1] ) : T [1]
}

Container <|-- Hash
Container <|-- List
Container <|-- Set
Container <|-- Array

@enduml