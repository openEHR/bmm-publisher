@startuml

abstract class VIEW_ENTRY {
}

abstract class VIEW_ITEM {
  + meta_data : CLUSTER [0..1]
}

class VIEW_SECTION {
  + items : List<VIEW_ITEM> [*]
}

class CITATION <L> {
  + source_type : String [0..1]
  + source_ref : LOCATABLE_REF [1]
  + source_parent_ref : LOCATABLE_REF [1]
  + resolved : L [1]
}

abstract class CONTENT_ITEM #whitesmoke;line:gray;line.dotted;text:gray {
}

enum VIEW_STATUS {
  active 
  inactive 
}

VIEW_ITEM <|-- VIEW_ENTRY
CONTENT_ITEM <|-- VIEW_ITEM
VIEW_ITEM <|-- VIEW_SECTION
VIEW_ENTRY <|-- CITATION

@enduml