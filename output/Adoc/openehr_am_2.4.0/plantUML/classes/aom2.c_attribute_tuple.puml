@startuml

class C_ATTRIBUTE_TUPLE {
  + tuples : List<C_PRIMITIVE_TUPLE> [*]
  + members : List<C_ATTRIBUTE> [*]
  + c_conforms_to( other : C_ATTRIBUTE_TUPLE [1], rmcc : FUNCTION<Boolean,TUPLE2<String,String>> [1] ) : Boolean [1]
  + c_congruent_to( other : C_SECOND_ORDER [1] ) : Boolean [1]
}

abstract class C_SECOND_ORDER  #whitesmoke;line:gray;line.dotted;text:gray {
  + members : List<ARCHETYPE_CONSTRAINT> [*]
  + {abstract} c_conforms_to( other : C_SECOND_ORDER [1], rmcc : FUNCTION<Boolean,TUPLE2<String,String>> [1] ) : Boolean [1]
  + {abstract} c_congruent_to( other : C_SECOND_ORDER [1] ) : Boolean [1]
}

C_SECOND_ORDER <|-- C_ATTRIBUTE_TUPLE


@enduml