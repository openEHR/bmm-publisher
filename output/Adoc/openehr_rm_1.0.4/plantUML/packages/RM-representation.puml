@startuml

abstract class ITEM {
}

abstract class LOCATABLE #whitesmoke;line:gray;line.dotted;text:gray {
}

class CLUSTER {
  + items : List<ITEM> [1..*]
}

class ELEMENT {
  + null_flavour : DV_CODED_TEXT [0..1]
  + value : DATA_VALUE [0..1]
  + is_null() : Boolean [1]
}

LOCATABLE <|-- ITEM
ITEM <|-- CLUSTER
ITEM <|-- ELEMENT

@enduml