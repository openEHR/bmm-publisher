@startuml

class BMM_BOOLEAN_VALUE {
  + value : Boolean [1]
}

class BMM_PRIMITIVE_VALUE  #whitesmoke;line:gray;line.dotted;text:gray {
  + type : BMM_SIMPLE_TYPE [1]
}

abstract class BMM_UNITARY_VALUE <T>  #whitesmoke;line:gray;line.dotted;text:gray {
}

abstract class BMM_LITERAL_VALUE <T>  #whitesmoke;line:gray;line.dotted;text:gray {
  + value_literal : String [1]
  + value : Any [0..1]
  + syntax : String [0..1]
  + type : T [1]
}

BMM_LITERAL_VALUE <|-- BMM_UNITARY_VALUE

BMM_UNITARY_VALUE <|-- BMM_PRIMITIVE_VALUE

BMM_PRIMITIVE_VALUE <|-- BMM_BOOLEAN_VALUE


@enduml