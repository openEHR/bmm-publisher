@startuml

abstract class BMM_CLASSIFIER {
  + type_name() : String [1]
  + type_category() : String [1]
  + type_signature() : String [1]
  + base_class() : BMM_CLASS [1]
  + flattened_type_list() : List<String> [*]
}

abstract class BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + documentation : String [0..1]
}

class BMM_DEFINITIONS  #whitesmoke;line:gray;line.dotted;text:gray {
}

BMM_DEFINITIONS <|-- BMM_MODEL_ELEMENT

BMM_MODEL_ELEMENT <|-- BMM_CLASSIFIER


@enduml