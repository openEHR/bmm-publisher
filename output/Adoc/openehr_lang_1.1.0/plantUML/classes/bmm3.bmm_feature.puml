@startuml

abstract class BMM_FEATURE {
  + is_synthesised_generic : Boolean [0..1]
  + feature_extensions : List<BMM_FEATURE_EXTENSION> [*]
  + group : BMM_FEATURE_GROUP [1]
  + scope : BMM_CLASS [1]
}

abstract class BMM_FORMAL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + type : BMM_TYPE [1]
  + is_nullable : Boolean [0..1]
  + {abstract} signature() : BMM_SIGNATURE [1]
  + is_boolean() : Boolean [1]
}

abstract class BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : String [1]
  + documentation : Hash<String,Any> [0..1]
  + scope : BMM_MODEL_ELEMENT [1]
  + extensions : Hash<String,Any> [0..1]
  + is_root_scope() : Boolean [1]
}

BMM_MODEL_ELEMENT <|-- BMM_FORMAL_ELEMENT

BMM_FORMAL_ELEMENT <|-- BMM_FEATURE


@enduml