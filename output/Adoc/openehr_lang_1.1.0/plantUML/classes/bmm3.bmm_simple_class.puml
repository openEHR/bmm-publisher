@startuml

class BMM_SIMPLE_CLASS {
  + type() : BMM_SIMPLE_TYPE [1]
}

abstract class BMM_CLASS  #whitesmoke;line:gray;line.dotted;text:gray {
  + ancestors : Hash<String,BMM_MODEL_TYPE> [0..1]
  + package : BMM_PACKAGE [1]
  + properties : Hash<String,BMM_PROPERTY> [0..1]
  + source_schema_id : String [1]
  + immediate_descendants : List<BMM_CLASS> [*]
  + is_override : Boolean [1]
  + static_properties : Hash<String,BMM_STATIC> [0..1]
  + functions : Hash<String,BMM_FUNCTION> [0..1]
  + procedures : Hash<String,BMM_PROCEDURE> [0..1]
  + is_primitive : Boolean [0..1]
  + is_abstract : Boolean [0..1]
  + invariants : List<BMM_ASSERTION> [*]
  + creators : Hash<String,BMM_PROCEDURE> [0..1]
  + converters : Hash<String,BMM_PROCEDURE> [0..1]
  + features : List<BMM_FEATURE> [*]
  + {abstract} type() : BMM_MODEL_TYPE [1]
  + all_ancestors() : List<String> [*]
  + all_descendants() : List<String> [*]
  + suppliers() : List<String> [*]
  + suppliers_non_primitive() : List<String> [*]
  + supplier_closure() : List<String> [*]
  + package_path() : String [1]
  + class_path() : String [1]
  + is_primitive() : Boolean [1]
  + is_abstract() : Boolean [1]
  + features() : List<Any> [*]
  + flat_features() : List<Any> [*]
  + flat_properties() : List<BMM_PROPERTY> [*]
}

abstract class BMM_MODULE  #whitesmoke;line:gray;line.dotted;text:gray {
  + scope : BMM_MODEL [1]
  + feature_groups : List<BMM_FEATURE_GROUP> [*]
  + features : List<BMM_FORMAL_ELEMENT> [*]
}

abstract class BMM_MODEL_ELEMENT  #whitesmoke;line:gray;line.dotted;text:gray {
  + name : String [1]
  + documentation : Hash<String,Any> [0..1]
  + scope : BMM_MODEL_ELEMENT [1]
  + extensions : Hash<String,Any> [0..1]
  + is_root_scope() : Boolean [1]
}

BMM_MODEL_ELEMENT <|-- BMM_MODULE

BMM_MODULE <|-- BMM_CLASS

BMM_CLASS <|-- BMM_SIMPLE_CLASS


@enduml