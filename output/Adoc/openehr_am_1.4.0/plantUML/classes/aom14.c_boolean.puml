@startuml

class C_BOOLEAN {
  + true_valid : Boolean [1]
  + false_valid : Boolean [1]
  + assumed_value : Boolean [0..1]
}

abstract class C_PRIMITIVE  #whitesmoke;line:gray;line.dotted;text:gray {
  + assumed_value : Any [0..1]
  + {abstract} default_value() : Any [1]
  + {abstract} has_assumed_value() : Boolean [1]
  + {abstract} valid_value( a_value : Any [1] ) : Boolean [1]
}

C_PRIMITIVE <|-- C_BOOLEAN


@enduml